# Clerk, see https://clerk.com/docs/quickstarts/nextjs
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Managed Postgres for Prisma
DATABASE_URL=

# Concierge model default for MVP. Leave OPENAI_API_KEY empty to use deterministic fallback.
OPENAI_API_KEY=
CONCIERGE_MODEL=gpt-4o-mini

# Development and screenshots only. Set true to force file-backed local fallback even if DATABASE_URL exists.
MINIONMINT_FORCE_LOCAL_STORE=false

# Computer provider selection: local_stub, self_hosted, remote_ssh
MINIONMINT_COMPUTER_PROVIDER=remote_ssh

# Hermes template or base image reference
MINIONMINT_HERMES_TEMPLATE_REF=local-hermes-template

# Credential vault provider: local or postgres
MINIONMINT_CREDENTIAL_VAULT_PROVIDER=local

# Network type: datacenter, residential_static, residential_rotating, vpn_tunnel, direct
MINIONMINT_NETWORK_TYPE=datacenter

# Remote SSH computer provider configuration
MINIONMINT_SSH_HOST=
MINIONMINT_SSH_PORT=22
MINIONMINT_SSH_USERNAME=
MINIONMINT_SSH_PASSWORD=
MINIONMINT_SSH_PRIVATE_KEY_PATH=
MINIONMINT_SSH_WORKSPACE_BASE=/root/minion-workspaces
MINIONMINT_SSH_CONSOLE_BASE_URL=
MINIONMINT_SSH_HERMES_INSTALL_URL=https://raw.githubusercontent.com/NousResearch/hermes-agent/main/scripts/install.sh

# Residential proxy configuration (when MINIONMINT_NETWORK_TYPE=residential_static)
MINIONMINT_RESIDENTIAL_PROXY_HOST=
MINIONMINT_RESIDENTIAL_PROXY_PORT=
MINIONMINT_RESIDENTIAL_PROXY_USER=
MINIONMINT_RESIDENTIAL_PROXY_PASS=
MINIONMINT_DISABLE_WEBRTC=true
MINIONMINT_PROXY_DNS=true

# VPN tunnel configuration (when MINIONMINT_NETWORK_TYPE=vpn_tunnel)
MINIONMINT_VPN_TYPE=wireguard
MINIONMINT_VPN_CONFIG_PATH=
MINIONMINT_VPN_KILL_SWITCH=true

# Self-hosted provider (legacy local supervisor)
MINIONMINT_SELF_HOSTED_WORKSPACE_ROOT=
MINIONMINT_SELF_HOSTED_EXECUTABLE=
MINIONMINT_SELF_HOSTED_ARGS_JSON=
MINIONMINT_SELF_HOSTED_CONSOLE_BASE_URL=
MINIONMINT_SELF_HOSTED_HEALTH_URL=
MINIONMINT_SELF_HOSTED_HEALTH_EXECUTABLE=
MINIONMINT_SELF_HOSTED_HEALTH_ARGS_JSON=
MINIONMINT_SELF_HOSTED_MAX_RESTARTS=3
MINIONMINT_SELF_HOSTED_RESTART_DISABLED=false

# Model provider for Minion Hermes instances
MINIONMINT_MODEL_PROVIDER=openai
