{
  "name": "agent-os-cloud-platform",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "agent-os-cloud-platform",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "devDependencies": {},
      "engines": {
        "node": ">=20.20.0",
        "npm": ">=10.0.0"
      }
    },
    "apps/api": {
      "name": "@agent-os/api",
      "version": "0.1.0"
    },
    "apps/web": {
      "name": "@agent-os/web",
      "version": "0.1.0"
    },
    "node_modules/@agent-os/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@agent-os/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@agent-os/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/shared": {
      "name": "@agent-os/shared",
      "version": "0.1.0"
    }
  }
}
